{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch SmartJob.API",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build SmartJob.API",
      "program": "${workspaceFolder}/SmartJob.API/bin/Debug/net10.0/SmartJob.API.dll",
      "args": [],
      "cwd": "${workspaceFolder}/SmartJob.API",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "DOTNET_CLI_HOME": "${workspaceFolder}/.dotnet"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      }
    },
    {
      "name": "Attach to SmartJob.API",
      "type": "coreclr",
      "request": "attach"
    }
  ]
}