{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=tcp:your_prod_server.database.windows.net,1433;Initial Catalog=SmartJobDb;Persist Security Info=False;User ID=admin;Password=YourPassword123!;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"
  },
  "Jwt": {
    "Key": "A-VERY-SECURE-AND-LONG-RANDOM-KEY-FOR-PRODUCTION-ENVIRONMENT-12345",
    "Issuer": "SmartJob.API.Production",
    "Audience": "SmartJob.Clients",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "FileStorage": {
    "BaseDirectory": "wwwroot/uploads",
    "MaxFileSizeInMB": 5
  }
}
